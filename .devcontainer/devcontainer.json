{
  "name": "QGIS Plugin Dev",
  "build": { "dockerfile": "Dockerfile" },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/gisquick_project_from_file,type=bind",
  "workspaceFolder": "/workspaces/gisquick_project_from_file",
  "remoteEnv": {
    "QT_QPA_PLATFORM": "offscreen",
    "PYTHONPATH": "/workspaces"
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.pylance"],
      "settings": {
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  }
}
